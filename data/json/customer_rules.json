{
  "id": "customer-validation",
  "description": "Customer validation workflow",
  "isActive": true,
  "rules": [
    {
      "id": "adult-check",
      "description": "Adult customer check",
      "expression": "customer.age >= 18",
      "action": "customer.processed = true",
      "isActive": true,
      "priority": 1,
      "dependsOnRuleId": null,
      "childRules": [],
      "timeout": null,
      "cacheDuration": null
    },
    {
      "id": "name-check",
      "description": "Name not empty check",
      "expression": "isNotEmpty(customer.name)",
      "isActive": true,
      "priority": 0,
      "dependsOnRuleId": null,
      "childRules": [],
      "timeout": null,
      "cacheDuration": null
    },
    {
      "id": "active-check",
      "description": "Customer is active",
      "expression": "customer.isActive == true",
      "isActive": true,
      "priority": 2,
      "dependsOnRuleId": null,
      "childRules": [],
      "timeout": null,
      "cacheDuration": null
    }
  ]
}
