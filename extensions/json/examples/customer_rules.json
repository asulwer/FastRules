{
  "id": 1,
  "name": "customerValidation",
  "description": "Customer validation workflow",
  "isActive": true,
  "rules": [
    {
      "id": 1,
      "name": "checkAdult",
      "description": "Adult customer check",
      "expression": "customer.age >= 18",
      "action": "customer.processed = true",
      "isActive": true,
      "priority": 1
    },
    {
      "id": 2,
      "name": "checkNameNotEmpty",
      "description": "Name not empty check",
      "expression": "isNotEmpty(customer.name)",
      "isActive": true,
      "priority": 0
    },
    {
      "id": 3,
      "name": "checkIsActive",
      "description": "Customer is active",
      "expression": "customer.isActive == true",
      "isActive": true,
      "priority": 2
    }
  ]
}
