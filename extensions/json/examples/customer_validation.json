{
  "id": 1,
  "description": "Customer validation with typed objects",
  "isActive": true,
  "rules": [
    {
      "id": 1,
      "expression": "context.getResult('age-check').success == true and context.getResult('name-check').success == true",
      "action": "customer.processed = true",
      "isActive": true,
      "priority": 2,
      "childRules": [
        {
          "id": 10,
          "expression": "customer.age >= 18",
          "isActive": true
        },
        {
          "id": 11,
          "expression": "isNotEmpty(customer.name)",
          "isActive": true
        }
      ]
    },
    {
      "id": 2,
      "expression": "context.getResult('minor-age-check').success == true",
      "action": "customer.processed = false",
      "isActive": true,
      "priority": 0,
      "childRules": [
        {
          "id": 20,
          "expression": "customer.age < 18",
          "isActive": true
        }
      ]
    },
    {
      "id": 3,
      "expression": "context.getResult('vip-status-check').success == true",
      "action": "customer.processed = true",
      "isActive": false,
      "priority": 1,
      "childRules": [
        {
          "id": 30,
          "expression": "customer.age >= 50",
          "isActive": true
        }
      ]
    }
  ]
}
