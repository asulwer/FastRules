<?xml version="1.0"?>
<workflow id="1" isActive="true">
<rules>
  <rule id="1" isActive="true" priority="2">
    <description>Process adult customers</description>
    <expression>customer.age &gt;= 18 and isNotEmpty(customer.name)</expression>
    <action>print('Adult processed: ' .. customer.name)</action>
  </rule>
  <rule id="2" isActive="true" priority="0">
    <description>Process minor customers</description>
    <expression>customer.age &lt; 18</expression>
    <action>print('Minor processed: ' .. customer.name)</action>
  </rule>
  <rule id="3" isActive="false" priority="1">
    <description>VIP processing (inactive)</description>
    <expression>customer.age &gt;= 50</expression>
    <action>print('VIP processed: ' .. customer.name)</action>
  </rule>
</rules>
</workflow>