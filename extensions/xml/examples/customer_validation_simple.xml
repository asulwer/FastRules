<?xml version="1.0"?>
<workflow id="1" name="customerValidationSimple" isActive="true">
  <rules>
    <rule id="1" name="processAdult" isActive="true" priority="2">
      <description>Process adult customers</description>
      <expression>customer.age &gt;= 18 and isNotEmpty(customer.name)</expression>
      <action>print(&apos;Adult processed: &apos; .. customer.name)</action>
    </rule>
    <rule id="2" name="processMinor" isActive="true" priority="0">
      <description>Process minor customers</description>
      <expression>customer.age &lt; 18</expression>
      <action>print(&apos;Minor processed: &apos; .. customer.name)</action>
    </rule>
    <rule id="3" name="processVip" isActive="false" priority="1">
      <description>VIP processing (inactive)</description>
      <expression>customer.age &gt;= 50</expression>
      <action>print(&apos;VIP processed: &apos; .. customer.name)</action>
    </rule>
  </rules>
</workflow>
