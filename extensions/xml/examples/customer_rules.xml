<?xml version="1.0"?>
<workflow id="1" name="customerValidation" isActive="true">
  <rules>
    <rule id="1" name="checkAdult" isActive="true" priority="1">
      <description>Adult customer check</description>
      <expression>customer.age >= 18</expression>
      <action>customer.processed = true</action>
    </rule>
    <rule id="2" name="checkNameNotEmpty" isActive="true" priority="0">
      <description>Name not empty check</description>
      <expression>isNotEmpty(customer.name)</expression>
    </rule>
    <rule id="3" name="checkIsActive" isActive="true" priority="2">
      <description>Customer is active</description>
      <expression>customer.isActive == true</expression>
    </rule>
  </rules>
</workflow>
