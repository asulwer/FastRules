<?xml version="1.0"?>
<workflow id="1" isActive="true">
<rules>
  <rule id="1" isActive="true" priority="0">
    <description>Validate input parameters</description>
    <expression>isNotNull(customer) and isNotEmpty(customer.name)</expression>
    <parameters>
      <param>customer</param>
    </parameters>
  </rule>
  <rule id="2" isActive="true" priority="1">
    <description>Check age requirement</description>
    <expression>customer.age &gt;= 21</expression>
    <dependencies>
      <dep>1</dep>
    </dependencies>
  </rule>
  <rule id="3" isActive="true" priority="2">
    <description>Process the customer</description>
    <expression>context.getResult(2).success</expression>
    <action>customer.processed = true</action>
    <dependencies>
      <dep>2</dep>
    </dependencies>
  </rule>
</rules>
</workflow>