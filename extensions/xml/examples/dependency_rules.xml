<?xml version="1.0"?>
<workflow id="1" name="dependencyRules" isActive="true">
  <rules>
    <rule id="1" name="validateInput" isActive="true" priority="0">
      <description>Validate input parameters</description>
      <expression>isNotNull(customer) and isNotEmpty(customer.name)</expression>
    </rule>
    <rule id="2" name="checkAge" isActive="true" priority="1">
      <description>Check age requirement</description>
      <expression>customer.age &gt;= 21</expression>
      <dependsOnRuleName>validateInput</dependsOnRuleName>
    </rule>
    <rule id="3" name="processCustomer" isActive="true" priority="2">
      <description>Process the customer</description>
      <expression>context.getResult(&apos;checkAge&apos;).success</expression>
      <action>customer.processed = true</action>
      <dependsOnRuleName>checkAge</dependsOnRuleName>
    </rule>
  </rules>
</workflow>
