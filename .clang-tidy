---
# Clang-tidy configuration for FastRules
# Focus on high-value checks, filter noise

Checks: >
  bugprone-*,
  cppcoreguidelines-*,
  modernize-*,
  performance-*,
  portability-*,
  readability-*,
  -cppcoreguidelines-avoid-magic-numbers,
  -cppcoreguidelines-pro-type-reinterpret-cast,
  -cppcoreguidelines-pro-type-vararg,
  -modernize-use-trailing-return-type,
  -readability-named-parameter,
  -readability-uppercase-literal-suffix,
  -readability-implicit-bool-conversion,
  -bugprone-easily-swappable-parameters

WarningsAsErrors: ''

HeaderFilterRegex: 'include/fastrules/.*'

CheckOptions:
  # Allow short variable names in loops
  - key:   readability-identifier-length.IgnoredVariableNames
    value: 'i|j|k|x|y|z|it|_'
  # Allow short names in for-range loops
  - key:   readability-identifier-length.IgnoredLoopVariableNames
    value: 'i|j|k|x|y|z|it|_|id'
  # Allow 2-letter type aliases
  - key:   readability-identifier-length.MinimumTypeNameLength
    value: 3
  # Don't force const& for cheap-to-copy types
  - key:   cppcoreguidelines-avoid-const-or-ref-data-members.IncludePointers
    value: 0
  # Allow exceptions (we use them for error handling)
  - key:   cppcoreguidelines-avoid-exceptions.WarnOnLargeFunctions
    value: 0
  # Allow non-const references (needed for output params)
  - key:   cppcoreguidelines-avoid-non-const-global-variables
    value: 0
  # Allow implicit bool conversion in conditions
  - key:   readability-implicit-bool-conversion.AllowIntegerConditions
    value: 1
  - key:   readability-implicit-bool-conversion.AllowPointerConditions
    value: 1
  # Allow designated initializers (modern C++20 feature)
  - key:   modernize-use-designated-initializers.IgnoreMacros
    value: 0
  # Allow brace initialization for return statements
  - key:   modernize-return-braced-init-list
    value: 0
  # Namespace comments are optional for short namespaces
  - key:   llvm-namespace-comment.ShortNamespaceLines
    value: 10

# Exclude generated files and third-party code
ExcludeHeaderFilterRegex: >
  (_deps|vcpkg_installed|build_|\.cache|third_party|external)/.*
