{
  "name": "fastrules",
  "version": "0.1.0",
  "description": "High-performance C++23 business rules engine with Lua expressions",
  "homepage": "https://github.com/asulwer/fastrules",
  "license": "MIT",
  "dependencies": [
    {
      "name": "lua",
      "version>=": "5.4.6"
    },
    {
      "name": "spdlog",
      "version>=": "1.14.0",
      "default-features": false
    }
  ],
  "features": {
    "json": {
      "description": "JSON persistence and serialization support",
      "dependencies": [
        {
          "name": "nlohmann-json",
          "default-features": false
        }
      ]
    },
    "xml": {
      "description": "XML persistence support",
      "dependencies": [
        {
          "name": "pugixml",
          "default-features": false
        }
      ]
    },
    "db": {
      "description": "Database persistence via SOCI with SQLite3 support",
      "dependencies": [
        {
          "name": "soci",
          "features": ["sqlite3"],
          "default-features": false
        }
      ]
    },
    "tests": {
      "description": "Build test suite",
      "dependencies": ["doctest"]
    }
  }
}